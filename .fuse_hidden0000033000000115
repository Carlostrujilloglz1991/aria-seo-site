<tr><td>University of Miami</td><td>DNP</td><td>36 months</td><td>Coral Gables / Miami</td></tr>
<tr><td>Florida State University (FSU)</td><td>DNP</td><td>36 months</td><td>Panama City / Tallahassee</td></tr>
<tr><td>Florida Gulf Coast University (FGCU)</td><td>DNP</td><td>36 months</td><td>Fort Myers</td></tr>
<tr><td>University of North Florida (UNF)</td><td>DNP</td><td>36 months</td><td>Jacksonville</td></tr>
