    <tr><td>{LATEST BP}</td><td>Most recent blood pressure</td><td>Quick vitals reference in notes</td></tr>
    <tr><td>{LATEST HR}</td><td>Most recent heart rate</td><td>Quick vitals reference</td></tr>
    <tr><td>{LATEST TEMP}</td><td>Most recent temperature</td><td>Fever/hypothermia documentation</td></tr>
    <tr><td>{LABS}</td><td>Recent lab results</td><td>Assessment, response-to-treatment notes</td></tr>
    <tr><td>{WEIGHT}</td><td>Most recent documented weight</td><td>Medication dosing notes, fluid balance</td></tr>
